{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["ANDROID_HOME", "ANDROID_SDK_ROOT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "codegen"],
      "outputs": ["lib/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "codegen": {
      "inputs": ["src/**/*.nitro.ts", "nitro.json", "package.json"],
      "outputs": ["nitrogen/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:cpp": {
      "cache": false,
      "outputLogs": "new-only"
    },
    "size": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
