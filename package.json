{
  "name": "react-native-nitro-markdown-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "publish-package": "node scripts/publish.js",
    "publish-package:dry-run": "node scripts/publish.js --dry-run --yes",
    "audit:package": "node scripts/publish.js --dry-run --skip-preflight --skip-checks --skip-docs --yes",
    "harness": "node scripts/harness.js",
    "dev": "bun run example:start",
    "check": "bun run lint && bun run typecheck && bun run test && bun run test:cpp",
    "check:ci": "bun run harness",
    "release:preflight": "bun run check:ci && bun run example:check && bun run audit:package && bun run publish-package:dry-run",
    "build": "turbo run build",
    "lint": "bun run --cwd packages/react-native-nitro-markdown lint",
    "clean": "turbo run clean",
    "codegen": "turbo run codegen",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:cpp": "turbo run test:cpp --filter=react-native-nitro-markdown",
    "test:cpp:coverage": "turbo run test:cpp:coverage --filter=react-native-nitro-markdown",
    "benchmark": "node scripts/benchmark-comparison.js",
    "example:start": "bun run --cwd apps/example start",
    "example:ios": "bun run --cwd apps/example ios",
    "example:android": "bun run --cwd apps/example android",
    "example:prebuild": "bun run --cwd apps/example prebuild",
    "example:prebuild:clean": "bun run --cwd apps/example prebuild:clean",
    "example:doctor": "bun run --cwd apps/example doctor",
    "example:lint": "bun run --cwd apps/example lint",
    "example:typecheck": "bun run --cwd apps/example typecheck",
    "example:check": "bun run example:doctor && bun run example:lint && bun run example:typecheck",
    "example:android:assemble": "bun run --cwd apps/example android:assemble",
    "example:ios:build": "bun run --cwd apps/example ios:build",
    "example:smoke": "node scripts/example-smoke.js",
    "example:smoke:android": "node scripts/example-smoke.js --android",
    "example:smoke:ios": "node scripts/example-smoke.js --ios"
  },
  "devDependencies": {
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@types/commonmark": "^0.27.10",
    "@types/jest": "^29.5.14",
    "@types/markdown-it": "^14.1.2",
    "@types/marked": "^6.0.0",
    "@types/node": "^20.19.41",
    "@types/react": "~19.2.15",
    "commonmark": "^0.31.2",
    "eslint-config-expo": "^56.0.4",
    "jest": "^29.7.0",
    "markdown-it": "^14.1.1",
    "marked": "^17.0.6",
    "nitrogen": "0.35.7",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.14",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-nitro-modules": "0.35.7",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-linking": "~56.0.13"
  },
  "dependencies": {
    "react-native-nitro-modules": "0.35.7"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "@swc/core",
    "unrs-resolver"
  ]
}
